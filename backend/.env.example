# ── LINE Messaging API 設定步驟 ───────────────────────────────────────────────
#
# 2024/09 起，Messaging API Channel 必須透過 LINE Official Account Manager 建立：
#
# Step 1. 申請 LINE 官方帳號
#   → https://account.line.biz/signup
#   使用 LINE 帳號或 Email 建立 Business ID，填寫官方帳號資料
#
# Step 2. 在 LINE Official Account Manager 啟用 Messaging API
#   → https://manager.line.biz/
#   選擇帳號 → 設定 → Messaging API → 啟用
#   （首次使用會要求輸入開發者姓名 & Email，並選擇 Provider）
#
# Step 3. 取得 Channel Access Token
#   → https://developers.line.biz/console/
#   選擇剛建立的 Channel → Messaging API 頁籤
#   → Issue / Reissue channel access token（long-lived）
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# Step 4. 取得你的 User ID（推播對象）
#   方式 A（個人）：Developers Console → Channel → Basic Settings → Your user ID
#                  格式：Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   方式 B（群組）：將 Bot 加入群組 → 設定 Webhook URL → 從 webhook 事件取得 groupId
#                  格式：Cxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   ⚠ 務必先在 LINE 把該官方帳號加為好友，否則 Push Message 回傳 403
LINE_TARGET_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# 需在 Google 帳號開啟「兩步驟驗證」，再產生「應用程式密碼」（非登入密碼）
# 設定：Google 帳號 → 安全性 → 兩步驟驗證 → 應用程式密碼（選 Mail）
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
EMAIL_TO=recipient@gmail.com
